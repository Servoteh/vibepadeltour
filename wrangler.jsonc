{
  // Cloudflare Worker sa STATIČKIM fajlovima (Faza 1 = static export).
  // `npm run build` generiše ./out, a `wrangler deploy` ga uploaduje kao statički sajt.
  // Bez OpenNext-a (njega uvodimo u Fazi 2 kad dodamo server/admin/Supabase).
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vibepadeltour",
  "compatibility_date": "2026-06-22",
  "assets": {
    "directory": "./out",
    "not_found_handling": "404-page"
  }
}
