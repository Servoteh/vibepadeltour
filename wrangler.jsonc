    "SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJ2aWljbWRheGZ3c2ZzZGxjc3NvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIxNjc1NTksImV4cCI6MjA5Nzc0MzU1OX0.ORHP7aAuo_wsHwaXXIfXl2AD-BkS3RaspKrQW-x7tn0"
  }
